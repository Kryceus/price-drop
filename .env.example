DB_HOST=localhost
DB_PORT=5432
DB_NAME=pricecompare
DB_USER=postgres
DB_PASSWORD=your_database_password_here
VITE_API_BASE=http://127.0.0.1:8080
FRONTEND_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,capacitor://localhost
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
# For a deployed HTTPS backend used by the Android app, use:
# SESSION_COOKIE_SAMESITE=None
# SESSION_COOKIE_SECURE=true
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# Or set FIREBASE_CREDENTIALS_JSON to the full Firebase service-account JSON in production.
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
